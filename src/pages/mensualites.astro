---
import Layout from "../layouts/Layout.astro";

const title = "Campagne 600 m² | Projet Rénovation CCMA";
const description =
    "Financez des m² pour la mosquée. Choisissez votre surface et réglez en une ou plusieurs fois.";
---

<Layout title={title} description={description}>
    <!-- Hero Section -->
    <section
        class="relative pt-24 md:pt-32 pb-12 md:pb-24 overflow-hidden bg-[#FDFCF9]"
    >
        <div
            class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-[300px] md:w-[600px] h-[300px] md:h-[600px] bg-[#5EB363]/10 rounded-full blur-[80px] md:blur-[120px]"
        >
        </div>
        <div class="max-w-4xl mx-auto px-4 md:px-6 text-center relative z-10">
            <div
                class="inline-flex items-center gap-2 bg-[#5EB363]/10 text-[#5EB363] px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-6"
            >
                <span class="relative flex h-2 w-2">
                    <span
                        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#5EB363] opacity-75"
                    ></span>
                    <span
                        class="relative inline-flex rounded-full h-2 w-2 bg-[#5EB363]"
                    ></span>
                </span>
                Campagne des m²
            </div>
            <h1
                class="text-4xl md:text-6xl lg:text-7xl font-black text-[#1A202C] leading-[1.1] mb-6 tracking-tight"
            >
                Offrez un espace de <br class="hidden md:block" />
                <span
                    class="bg-gradient-to-r from-[#2D648B] to-[#5EB363] bg-clip-text text-transparent"
                    >prière pour l'éternité.</span
                >
            </h1>
            <p
                class="text-lg md:text-xl text-slate-500 font-medium leading-relaxed max-w-2xl mx-auto px-2"
            >
                Participez à la construction en finançant des mètres carrés. Une
                Sadaqa Jariya dont les fruits perdureront insha'Allah.
            </p>
        </div>
    </section>

    <section class="py-8 md:py-16 bg-white relative z-20 md:-mt-8">
        <div class="max-w-5xl mx-auto px-4 md:px-6">
            <!-- Success View mode extracted to /success -->

            <!-- Etape 1: Choix de la surface -->
            <div
                id="step-1-container"
                class="space-y-10 md:space-y-16 animate-fade-in relative"
            >
                <div class="text-center">
                    <div
                        class="inline-flex items-center justify-center w-10 h-10 md:w-12 md:h-12 rounded-full bg-gradient-to-r from-[#2D648B] to-[#5EB363] text-white font-black text-lg md:text-xl mb-4 shadow-lg"
                    >
                        1
                    </div>
                    <h2
                        class="text-2xl md:text-4xl font-black text-[#1A202C] tracking-tight"
                    >
                        Quelle surface souhaitez-vous financer ?
                    </h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
                    <!-- 1/4 m2 -->
                    <button
                        class="surface-card w-full bg-slate-50 hover:bg-white rounded-[2rem] p-6 md:p-8 border-2 border-transparent group-[.active]:border-[#2D648B] group-[.active]:bg-white hover:border-slate-200 shadow-sm group-[.active]:shadow-xl hover:shadow-xl transition-all duration-300 text-left flex flex-row md:flex-col items-center md:items-start gap-5 md:gap-0 group active:scale-[0.98]"
                        data-surface="0.25"
                        data-price="300"
                        data-months="10"
                    >
                        <div
                            class="w-16 h-16 md:mb-8 rounded-[1.25rem] shrink-0 bg-white group-[.active]:bg-gradient-to-br group-[.active]:from-[#2D648B] group-[.active]:to-[#1A202C] border border-slate-100 group-[.active]:border-transparent shadow-sm group-[.active]:shadow-lg text-slate-400 group-[.active]:text-white flex items-center justify-center font-black text-2xl md:text-3xl transition-all group-hover:scale-110"
                        >
                            ¼
                        </div>
                        <div class="flex-1">
                            <h3
                                class="text-xl md:text-2xl font-black text-[#1A202C] mb-1"
                            >
                                Quart de m²
                            </h3>
                            <p
                                class="text-2xl md:text-4xl font-black text-[#2D648B]"
                            >
                                300 €
                            </p>
                        </div>
                        <div
                            class="radio-circle w-7 h-7 rounded-full border-2 border-slate-300 flex items-center justify-center group-[.active]:border-[#2D648B] group-[.active]:bg-[#2D648B] transition-colors shrink-0"
                        >
                            <svg
                                class="w-4 h-4 text-white opacity-0 group-[.active]:opacity-100 transition-opacity"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="3"
                                    d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                    </button>

                    <!-- 1/2 m2 (Premium) -->
                    <button
                        class="surface-card active w-full bg-slate-50 hover:bg-white group-[.active]:bg-white rounded-[2rem] p-6 md:p-8 border-2 border-transparent group-[.active]:border-[#5EB363] shadow-sm hover:shadow-2xl group-[.active]:shadow-2xl relative text-left flex flex-row md:flex-col items-center md:items-start gap-5 md:gap-0 group overflow-hidden cursor-pointer active:scale-[0.98] transition-all duration-300"
                        data-surface="0.5"
                        data-price="600"
                        data-months="12"
                    >
                        <!-- Decorative bg -->
                        <div
                            class="absolute -right-16 -top-16 w-48 h-48 bg-gradient-to-br from-[#5EB363]/5 to-[#2D648B]/5 group-[.active]:from-[#5EB363]/10 rounded-full blur-3xl transition-colors"
                        >
                        </div>
                        <!-- Badge -->
                        <div
                            class="absolute top-0 right-1/2 translate-x-1/2 md:translate-x-0 md:right-6 md:top-6 bg-slate-200 group-[.active]:bg-[#5EB363] text-slate-500 group-[.active]:text-white text-[10px] md:text-xs uppercase font-black tracking-widest px-4 md:px-5 py-1.5 rounded-bl-xl rounded-br-xl md:rounded-full shadow-sm group-[.active]:shadow-md z-20 transition-colors"
                        >
                            Populaire
                        </div>

                        <div
                            class="w-16 h-16 md:mb-8 rounded-[1.25rem] shrink-0 bg-white group-[.active]:bg-gradient-to-br group-[.active]:from-[#5EB363] group-[.active]:to-[#4ea253] border border-slate-100 group-[.active]:border-transparent text-slate-400 group-[.active]:text-white shadow-sm group-[.active]:shadow-[#5EB363]/30 flex items-center justify-center font-black text-2xl md:text-3xl transition-transform group-hover:scale-110 relative z-10 transition-colors"
                        >
                            ½
                        </div>
                        <div class="flex-1 relative z-10">
                            <h3
                                class="text-xl md:text-2xl font-black text-[#1A202C] mb-1 mt-3 md:mt-0"
                            >
                                Demi m²
                            </h3>
                            <p
                                class="text-2xl md:text-4xl font-black text-[#5EB363]"
                            >
                                600 €
                            </p>
                        </div>
                        <div
                            class="radio-circle w-7 h-7 rounded-full border-2 border-slate-300 group-[.active]:border-[#5EB363] group-[.active]:bg-[#5EB363] flex items-center justify-center shrink-0 relative z-10 transition-colors"
                        >
                            <svg
                                class="w-4 h-4 text-white opacity-0 group-[.active]:opacity-100 transition-opacity"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="3"
                                    d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                    </button>

                    <!-- 1 m2 -->
                    <button
                        class="surface-card w-full bg-slate-50 hover:bg-white rounded-[2rem] p-6 md:p-8 border-2 border-transparent group-[.active]:border-[#2D648B] group-[.active]:bg-white hover:border-slate-200 shadow-sm group-[.active]:shadow-xl hover:shadow-xl transition-all duration-300 text-left flex flex-row md:flex-col items-center md:items-start gap-5 md:gap-0 group active:scale-[0.98]"
                        data-surface="1"
                        data-price="1200"
                        data-months="12"
                    >
                        <div
                            class="w-16 h-16 md:mb-8 rounded-[1.25rem] shrink-0 bg-white group-[.active]:bg-gradient-to-br group-[.active]:from-[#2D648B] group-[.active]:to-[#1A202C] border border-slate-100 group-[.active]:border-transparent shadow-sm group-[.active]:shadow-lg text-slate-400 group-[.active]:text-white flex items-center justify-center font-black text-2xl md:text-3xl transition-all group-hover:scale-110"
                        >
                            1
                        </div>
                        <div class="flex-1">
                            <h3
                                class="text-xl md:text-2xl font-black text-[#1A202C] mb-1"
                            >
                                Mètre² complet
                            </h3>
                            <p
                                class="text-2xl md:text-4xl font-black text-[#2D648B]"
                            >
                                1200 €
                            </p>
                        </div>
                        <div
                            class="radio-circle w-7 h-7 rounded-full border-2 border-slate-300 flex items-center justify-center group-[.active]:border-[#2D648B] group-[.active]:bg-[#2D648B] transition-colors shrink-0"
                        >
                            <svg
                                class="w-4 h-4 text-white opacity-0 group-[.active]:opacity-100 transition-opacity"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="3"
                                    d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                    </button>
                </div>

                <!-- Custom Surface -->
                <div class="max-w-lg mx-auto">
                    <button
                        class="surface-card w-full bg-white rounded-2xl p-5 md:p-6 border-2 border-slate-100 shadow-sm hover:border-slate-300 group-[.active]:border-[#2D648B] group-[.active]:hover:border-[#2D648B] group-[.active]:shadow-md transition-all text-center flex items-center gap-4 group active:scale-[0.99]"
                        data-surface="custom"
                        data-price="0"
                        data-months="1"
                    >
                        <div
                            class="radio-circle shrink-0 w-7 h-7 rounded-full border-2 border-slate-300 flex items-center justify-center group-[.active]:border-[#2D648B] group-[.active]:bg-[#2D648B] transition-colors"
                        >
                            <svg
                                class="w-4 h-4 text-white opacity-0 group-[.active]:opacity-100 transition-opacity"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="3"
                                    d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <div class="flex-1 text-left">
                            <span
                                class="font-bold text-lg text-slate-500 group-hover:text-[#1A202C] group-[.active]:text-[#2D648B] transition-colors"
                                >Montant libre...</span
                            >
                        </div>
                    </button>
                    <!-- Custom Input (Hidden by default) -->
                    <div
                        id="custom-input-box"
                        class="hidden mt-4 bg-slate-50 p-6 md:p-8 rounded-[2rem] border border-slate-200 text-center shadow-inner"
                    >
                        <label
                            for="custom-total"
                            class="block text-sm md:text-base font-bold text-slate-500 mb-4"
                            >Indiquez le montant global de votre don</label
                        >
                        <div
                            class="flex items-center justify-center gap-3 max-w-[240px] mx-auto bg-white p-3 rounded-2xl border-2 border-slate-200 focus-within:border-[#2D648B] focus-within:ring-4 focus-within:ring-[#2D648B]/10 transition-all shadow-sm"
                        >
                            <input
                                type="number"
                                id="custom-total"
                                placeholder="150"
                                min="1"
                                class="w-full bg-transparent text-center text-3xl md:text-4xl font-black text-[#1A202C] outline-none placeholder-slate-300"
                            />
                            <span
                                class="text-2xl md:text-3xl font-black text-slate-300 pr-4"
                                >€</span
                            >
                        </div>
                        <p
                            id="custom-error"
                            class="hidden text-sm font-bold text-red-500 mt-4 animate-fade-in"
                        >
                            Le montant minimum est de 1€
                        </p>
                    </div>
                </div>

                <div class="text-center pt-8 pb-4">
                    <button
                        onclick="goToStep2()"
                        class="w-full md:w-auto px-10 md:px-14 py-4.5 bg-[#2D648B] text-white rounded-2xl font-bold text-lg shadow-xl shadow-[#2D648B]/20 hover:shadow-2xl hover:scale-[1.02] transition-all active:scale-95 inline-flex items-center justify-center gap-3"
                    >
                        Continuer
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2.5"
                                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Etape 2: Choix du mode de paiement (Hidden by default) -->
            <div
                id="step-2-container"
                class="hidden space-y-10 md:space-y-16 animate-fade-in pb-12 relative"
            >
                <div class="text-center">
                    <div
                        class="inline-flex items-center justify-center w-10 h-10 md:w-12 md:h-12 rounded-full bg-gradient-to-r from-[#2D648B] to-[#5EB363] text-white font-black text-lg md:text-xl mb-4 shadow-lg shadow-[#2D648B]/20"
                    >
                        2
                    </div>
                    <h2
                        class="text-2xl md:text-4xl font-black text-[#1A202C] tracking-tight"
                    >
                        Comment régler <span
                            id="summary-price"
                            class="text-[#5EB363]">600€</span
                        > ?
                    </h2>
                </div>

                <div
                    class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-10 max-w-4xl mx-auto"
                >
                    <!-- One Time -->
                    <button
                        onclick="startCheckout('payment')"
                        class="bg-slate-50 hover:bg-white rounded-[2rem] md:rounded-[3rem] p-8 md:p-12 border-2 border-transparent hover:border-slate-200 hover:shadow-2xl transition-all duration-300 text-center group cursor-pointer h-full flex flex-col justify-center relative overflow-hidden active:scale-[0.98]"
                    >
                        <div
                            class="absolute top-0 right-0 w-48 h-48 bg-white rounded-bl-[100px] -z-10 transition-transform duration-500 group-hover:scale-[1.5]"
                        >
                        </div>
                        <div
                            class="w-16 h-16 md:w-20 md:h-20 bg-white group-hover:bg-[#2D648B] text-slate-400 group-hover:text-white rounded-[1.5rem] flex items-center justify-center mx-auto mb-6 transition-all duration-300 shadow-sm group-hover:shadow-lg group-hover:scale-110"
                        >
                            <svg
                                class="w-8 h-8 md:w-10 md:h-10"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2.5"
                                    d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="text-2xl md:text-3xl font-black text-[#1A202C] mb-2 md:mb-3"
                        >
                            En 1 fois
                        </h3>
                        <p
                            id="total-onetime-display"
                            class="text-3xl md:text-5xl font-black text-[#2D648B] mb-6 md:mb-8"
                        >
                            600 €
                        </p>
                        <div
                            class="inline-flex items-center justify-center gap-2 text-xs md:text-sm font-bold text-[#2D648B] bg-[#2D648B]/10 px-5 py-2.5 rounded-full uppercase tracking-wider mx-auto transition-colors group-hover:bg-[#2D648B]/20"
                        >
                            Paiement immédiat
                        </div>
                    </button>

                    <!-- Monthly -->
                    <button
                        onclick="startCheckout('subscription')"
                        id="monthly-option-card"
                        class="bg-[#1A202C] rounded-[2rem] md:rounded-[3rem] p-8 md:p-12 shadow-2xl relative overflow-hidden group transition-all duration-300 transform md:hover:-translate-y-2 cursor-pointer text-center h-full flex flex-col justify-center active:scale-[0.98]"
                    >
                        <div
                            class="absolute inset-0 bg-gradient-to-br from-[#1a202c] to-[#2D648B]/40 z-0"
                        >
                        </div>
                        <div
                            class="absolute top-0 right-0 w-64 md:w-96 h-64 md:h-96 bg-gradient-to-bl from-[#5EB363]/20 to-transparent rounded-full blur-3xl -mr-16 -mt-16 transition-all duration-700 group-hover:scale-150 group-hover:opacity-70 z-0"
                        >
                        </div>

                        <div
                            class="relative z-10 w-16 h-16 md:w-20 md:h-20 bg-white/10 group-hover:bg-[#5EB363] text-white rounded-[1.5rem] flex items-center justify-center mx-auto mb-6 transition-all duration-300 shadow-lg group-hover:shadow-[#5EB363]/40 group-hover:scale-110 backdrop-blur-sm"
                        >
                            <svg
                                class="w-8 h-8 md:w-10 md:h-10"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2.5"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                        </div>
                        <h3
                            class="relative z-10 text-2xl md:text-3xl font-black text-white mb-2 md:mb-3"
                        >
                            Mensualités
                        </h3>
                        <p
                            class="relative z-10 text-4xl md:text-6xl font-black text-[#5EB363] mb-2 md:mb-3 drop-shadow-lg"
                        >
                            <span id="total-monthly-display">50 €</span><span
                                class="text-sm md:text-lg text-white/60 uppercase tracking-widest font-bold ml-1.5 drop-shadow-none"
                                >/mois</span
                            >
                        </p>
                        <p
                            id="monthly-duration-display"
                            class="relative z-10 text-slate-300 text-sm md:text-base font-medium mb-6 md:mb-8"
                        >
                            pendant 12 mois
                        </p>
                        <div
                            class="relative z-10 inline-flex items-center justify-center gap-2 text-sm md:text-base font-black text-[#1A202C] bg-white px-8 py-3.5 rounded-2xl shadow-xl group-hover:bg-[#5EB363] group-hover:text-white transition-colors duration-300 mx-auto w-full sm:w-auto"
                        >
                            Sélectionner
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="3"
                                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                            </svg>
                        </div>
                    </button>

                    <!-- Alert when custom amount is too small to divide -->
                    <div
                        id="monthly-error-card"
                        class="bg-slate-50 border-2 border-slate-100 rounded-[2rem] md:rounded-[3rem] p-8 md:p-12 text-center hidden flex-col justify-center h-full"
                    >
                        <div
                            class="w-16 h-16 bg-white text-slate-300 rounded-[1.5rem] flex items-center justify-center mx-auto mb-6 shadow-sm"
                        >
                            <svg
                                class="w-8 h-8"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                        </div>
                        <p
                            class="text-slate-500 font-medium text-base md:text-lg px-2 max-w-xs mx-auto"
                        >
                            Les paiements mensuels ne sont disponibles que pour
                            les montants supérieurs à 50€.
                        </p>
                    </div>
                </div>

                <div class="text-center pt-8 md:pt-12 w-full block">
                    <button
                        onclick="backToStep1()"
                        class="text-slate-400 text-base md:text-lg font-bold hover:text-[#1A202C] transition-colors p-4 inline-flex items-center gap-3 underline underline-offset-8 decoration-slate-200 hover:decoration-[#1A202C]"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2.5"
                                d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                        </svg>
                        Modifier la surface
                    </button>
                </div>
            </div>

            <!-- Stripe Checkout Container (Hidden initially) -->
            <div
                id="stripe-container"
                class="hidden max-w-4xl mx-auto mt-8 md:mt-16 bg-white rounded-[2rem] md:rounded-[3rem] p-6 md:p-10 shadow-2xl border border-slate-100 min-h-[600px] flex-col relative items-center justify-center animate-fade-in"
            >
                <button
                    onclick="cancelCheckout()"
                    class="absolute top-6 left-6 md:top-8 md:left-8 text-slate-400 hover:text-slate-900 flex items-center justify-center w-12 h-12 md:w-auto md:h-auto md:px-6 md:py-3 bg-slate-50 hover:bg-slate-100 rounded-full md:rounded-2xl font-bold text-sm md:text-base transition-colors z-10 group"
                    aria-label="Retour au choix"
                >
                    <svg
                        class="w-5 h-5 md:mr-3 transform group-hover:-translate-x-1 transition-transform"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    <span class="hidden md:inline"
                        >Changer de mode de paiement</span
                    >
                </button>

                <div
                    id="loading-spinner"
                    class="flex flex-col items-center justify-center py-24 md:py-32 animate-pulse w-full"
                >
                    <div
                        class="w-12 h-12 md:w-16 md:h-16 border-4 border-[#635BFF]/20 border-t-[#635BFF] rounded-full animate-spin mb-6 shadow-sm"
                    >
                    </div>
                    <p
                        class="text-slate-400 font-bold uppercase tracking-[0.2em] text-[10px] md:text-xs"
                    >
                        Connexion sécurisée...
                    </p>
                </div>

                <div id="checkout" class="w-full mt-16 md:mt-20"></div>
            </div>
        </div>
    </section>

    <script is:inline src="https://js.stripe.com/v3/"></script>
    <script is:inline>
        const stripe = Stripe(
            "pk_live_51MrgwnBg3GJXa4BP4VkSdwQrNkUcqjVJGQm2AvDQYiUbggTPNeYmTa3c2ktFG8NE9SHRLjFkJoxpGVzZUDwvAOac007G0v8plC"
        );
        let activeCheckout = null;

        let selectedPrice = 600; // default 1/2 m2
        let selectedMonths = 12;

        document.addEventListener("DOMContentLoaded", () => {
            // UI Selection Logic
            const cards = document.querySelectorAll(".surface-card");
            cards.forEach((card) => {
                card.addEventListener("click", (e) => {
                    // Reset all
                    cards.forEach((c) => c.classList.remove("active"));

                    // Activate selected
                    card.classList.add("active");

                    if (card.dataset.surface !== "custom") {
                        document
                            .getElementById("custom-input-box")
                            .classList.add("hidden");
                        selectedPrice = parseInt(card.dataset.price);
                        selectedMonths = parseInt(card.dataset.months);
                    } else {
                        document
                            .getElementById("custom-input-box")
                            .classList.remove("hidden");
                        const customInput =
                            document.getElementById("custom-total");
                        customInput.focus();
                        if (customInput.value) {
                            customInput.selectionStart =
                                customInput.selectionEnd =
                                    customInput.value.length;
                        }
                        selectedPrice = 0; // will be resolved in goToStep2
                    }
                });
            });
        });

        window.goToStep2 = () => {
            const errorElement = document.getElementById("custom-error");
            if (errorElement) errorElement.classList.add("hidden");

            if (
                document
                    .getElementById("custom-input-box")
                    .classList.contains("hidden") === false
            ) {
                // Custom amount selected
                const val = document.getElementById("custom-total").value;
                if (!val || isNaN(val) || val < 1) {
                    if (errorElement) errorElement.classList.remove("hidden");
                    return;
                }
                selectedPrice = parseInt(val);
                selectedMonths = 10; // default for custom is divide by 10
            }

            // Update UI for step 2
            document.getElementById("summary-price").textContent =
                selectedPrice + "€";
            document.getElementById("total-onetime-display").textContent =
                selectedPrice + " €";

            const monthlyAmt = Math.floor(selectedPrice / selectedMonths);

            if (monthlyAmt >= 5) {
                document
                    .getElementById("monthly-option-card")
                    .classList.remove("hidden");
                document
                    .getElementById("monthly-error-card")
                    .classList.add("hidden");
                document.getElementById("total-monthly-display").textContent =
                    monthlyAmt + " €";
                document.getElementById(
                    "monthly-duration-display"
                ).textContent = `pendant ${selectedMonths} mois`;
                selectedPriceMonthly = monthlyAmt; // dynamic global logic if needed
            } else {
                document
                    .getElementById("monthly-option-card")
                    .classList.add("hidden");
                document
                    .getElementById("monthly-error-card")
                    .classList.remove("hidden");
                document.getElementById("monthly-error-card").style.display =
                    "flex";
            }

            document.getElementById("step-1-container").style.display = "none";
            document.getElementById("step-2-container").style.display = "block";
            window.scrollTo({ top: 0, behavior: "smooth" });
        };

        window.backToStep1 = () => {
            document.getElementById("step-2-container").style.display = "none";
            document.getElementById("step-1-container").style.display = "block";
        };

        window.startCheckout = async (mode) => {
            document.getElementById("step-2-container").style.display = "none";

            const stripeContainer = document.getElementById("stripe-container");
            const spinner = document.getElementById("loading-spinner");
            const checkoutDiv = document.getElementById("checkout");

            stripeContainer.style.display = "flex";
            spinner.style.display = "flex";
            checkoutDiv.innerHTML = ""; // reset

            stripeContainer.scrollIntoView({
                behavior: "smooth",
                block: "start",
            });

            let finalAmount = selectedPrice;
            if (mode === "subscription") {
                finalAmount = Math.floor(selectedPrice / selectedMonths);
            }

            try {
                const response = await fetch("/.netlify/functions/checkout", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        amount: finalAmount,
                        interval: mode === "subscription" ? "month" : null,
                    }),
                });

                const data = await response.json();
                if (data.error) throw new Error(data.error);

                if (activeCheckout) {
                    activeCheckout.destroy();
                }

                activeCheckout = await stripe.initEmbeddedCheckout({
                    clientSecret: data.clientSecret,
                });

                spinner.style.display = "none";
                await activeCheckout.mount("#checkout");
            } catch (e) {
                console.error("Checkout init error:", e);
                spinner.style.display = "none";
                checkoutDiv.innerHTML = `<div class="p-8 text-center text-red-500 font-bold">Erreur de connexion : ${e.message}</div>`;
            }
        };

        window.cancelCheckout = () => {
            if (activeCheckout) {
                activeCheckout.destroy();
                activeCheckout = null;
            }
            document.getElementById("stripe-container").style.display = "none";
            document.getElementById("step-2-container").style.display = "block";
            window.scrollTo({ top: 0, behavior: "smooth" });
        };
    </script>
</Layout>

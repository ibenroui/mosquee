                    <script is:inline src="https://js.stripe.com/v3/"></script>
                    <script is:inline>
                        const stripe = Stripe(
                            "pk_live_51MrgwnBg3GJXa4BP4VkSdwQrNkUcqjVJGQm2AvDQYiUbggTPNeYmTa3c2ktFG8NE9SHRLjFkJoxpGVzZUDwvAOac007G0v8plC"
                        );
                        async function initialize() {
                            try {
                                const response = await fetch(
                                    "/.netlify/functions/checkout",
                                    {
                                        method: "POST",
                                        headers: {
                                            "Content-Type": "application/json",
                                        },
                                        body: JSON.stringify({}),
                                    }
                                );
                                if (!response.ok)
                                    throw new Error(
                                        `HTTP error! status: ${response.status}`
                                    );
                                const { clientSecret, error } =
                                    await response.json();
                                if (error) throw new Error(error);
                                const checkout =
                                    await stripe.initEmbeddedCheckout({
                                        clientSecret,
                                    });
                                document.getElementById(
                                    "loading-spinner"
                                ).style.display = "none";

                                // Save scroll position to prevent Stripe focus jump
                                const scrollPos = window.scrollY;
                                await checkout.mount("#checkout");
                                // Wait a bit for Stripe to finish its autofocus attempt then restore
                                setTimeout(
                                    () => window.scrollTo(0, scrollPos),
                                    10
                                );
                            } catch (e) {
                                console.error(
                                    "Stripe Initialization Error:",
                                    e
                                );
                                document.getElementById(
                                    "checkout"
                                ).innerHTML = `<div class="p-12 text-center"><p class="text-red-500 font-bold">Erreur : ${e.message}</p></div>`;
                            }
                        }
                        initialize();

                        // Donation Progress Logic
                        const collectedEl =
                            document.getElementById("collected-amount");
                        const percentageTextEl =
                            document.getElementById("percentage-text");
                        const progressBarEl =
                            document.getElementById("progress-bar");

                        async function fetchProgress() {
                            try {
                                const response = await fetch(
                                    `/.netlify/functions/stripe-progress?t=${new Date().getTime()}`,
                                    { cache: "no-store" }
                                );
                                const data = await response.json();

                                if (data.collected !== undefined) {
                                    // Remove skeleton states
                                    collectedEl.classList.remove(
                                        "animate-shimmer",
                                        "bg-white/5"
                                    );
                                    percentageTextEl.classList.remove(
                                        "animate-shimmer",
                                        "bg-white/5"
                                    );

                                    animateValue(
                                        collectedEl,
                                        0,
                                        data.collected,
                                        2000,
                                        " €"
                                    );
                                    animateValue(
                                        percentageTextEl,
                                        0,
                                        data.percentage,
                                        2000,
                                        "%"
                                    );

                                    const heroCollectedEl =
                                        document.getElementById(
                                            "hero-collected-text"
                                        );
                                    const heroPercentageEl =
                                        document.getElementById(
                                            "hero-percentage"
                                        );
                                    const heroProgressBarEl =
                                        document.getElementById(
                                            "hero-progress-bar"
                                        );

                                    if (heroPercentageEl) {
                                        heroPercentageEl.textContent =
                                            data.percentage + "%";
                                    }

                                    if (heroCollectedEl) {
                                        heroCollectedEl.classList.remove(
                                            "animate-shimmer",
                                            "bg-slate-50"
                                        );
                                        heroCollectedEl.textContent =
                                            data.collected.toLocaleString() +
                                            " € / 250 000 €";
                                    }

                                    // Smoothly grow the bars after a small delay
                                    setTimeout(() => {
                                        progressBarEl.style.width =
                                            data.percentage + "%";
                                        if (heroProgressBarEl)
                                            heroProgressBarEl.style.width =
                                                data.percentage + "%";
                                    }, 300);
                                }
                            } catch (e) {
                                console.error("Progress fetch error:", e);
                                // Fallback values if API fails
                                collectedEl.textContent = "1 830 €";
                                percentageTextEl.textContent = "1%";
                                progressBarEl.style.width = "1%";
                            }
                        }

                        function animateValue(
                            obj,
                            start,
                            end,
                            duration,
                            suffix = ""
                        ) {
                            let startTimestamp = null;
                            const step = (timestamp) => {
                                if (!startTimestamp) startTimestamp = timestamp;
                                const progress = Math.min(
                                    (timestamp - startTimestamp) / duration,
                                    1
                                );
                                const current = Math.floor(
                                    progress * (end - start) + start
                                );
                                obj.innerHTML =
                                    current.toLocaleString() + suffix;
                                if (progress < 1) {
                                    window.requestAnimationFrame(step);
                                }
                            };
                            window.requestAnimationFrame(step);
                        }

                        // Run on load
                        fetchProgress();
                    </script>


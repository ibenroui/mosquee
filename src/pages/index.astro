    <!-- Interactive Script -->
    <script is:inline>
        document.querySelectorAll(".step-btn").forEach((btn) => {
            btn.addEventListener("click", () => {
                document.querySelectorAll(".step-btn").forEach((b) => {
                    b.classList.remove("border-[#5EB363]", "bg-[#5EB363]/5");
                    b.classList.add("border-slate-100");
                    const details = b.querySelector(".step-details");
                    details.style.height = "0";
                    details.style.marginTop = "0";
                    details.style.opacity = "0";
                    const title = b.querySelector("h5");
                    const num = b.querySelector(".w-10");
                    const svg = b.querySelector("svg");
                    if (title) title.classList.add("text-slate-400");
                    if (num) {
                        num.classList.add("bg-slate-100", "text-slate-400");
                        num.classList.remove("bg-[#5EB363]", "text-white");
                    }
                    if (svg) svg.classList.remove("rotate-180");
                });
                btn.classList.add("border-[#5EB363]", "bg-[#5EB363]/5");
                btn.classList.remove("border-slate-100");
                const activeDetails = btn.querySelector(".step-details");
                activeDetails.style.height = "auto";
                activeDetails.style.marginTop = "1.5rem";
                activeDetails.style.opacity = "1";
                const activeTitle = btn.querySelector("h5");
                const activeNum = btn.querySelector(".w-10");
                const activeSvg = btn.querySelector("svg");
                if (activeTitle) activeTitle.classList.remove("text-slate-400");
                if (activeNum) {
                    activeNum.classList.remove(
                        "bg-slate-100",
                        "text-slate-400"
                    );
                    activeNum.classList.add("bg-[#5EB363]", "text-white");
                }
                if (activeSvg) activeSvg.classList.add("rotate-180");
            });
        });
        document.querySelectorAll(".copy-btn").forEach((btn) => {
            btn.addEventListener("click", () => {
                const targetId = btn.getAttribute("data-target");
                const text = document.getElementById(targetId).innerText;
                navigator.clipboard.writeText(text).then(() => {
                    const originalHtml = btn.innerHTML;
                    btn.innerHTML =
                        '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
                    btn.classList.add("bg-[#5EB363]");
                    setTimeout(() => {
                        btn.innerHTML = originalHtml;
                        btn.classList.remove("bg-[#5EB363]");
                    }, 2000);
                });
            });
        });
    </script>
